# http://editorconfig.org
root = true

[*]
indent_style = space
indent_size = 2
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# TypeScript / JavaScript specific
[*.{ts,tsx,js,jsx}]
quote_type = single

# Markdown files (often prefer 4 spaces or specific wrapping)
[*.md]
trim_trailing_whitespace = false
